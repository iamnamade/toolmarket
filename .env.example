# Do not commit real .env files.
# Use this file only as a template.
# Production variables must be configured in Vercel.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=""
DIRECT_URL=""

# Auth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Optional test/admin credentials. Use a strong password and keep it server-only.
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=

# Preferred Auth.js v5 Google credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Legacy aliases are also supported. Configure one complete pair only.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Console authorized redirect URI for this local URL:
# http://localhost:3000/api/auth/callback/google

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Security
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
